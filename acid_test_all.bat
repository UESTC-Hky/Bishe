@echo off
chcp 65001 > nul

echo.
echo ################################################################
echo #                                                              #
echo #     ACID 综合测试套件                                        #
echo #     事务数据库系统                                            #
echo #     原子性 / 一致性 / 隔离性 / 持久性                         #
echo #                                                              #
echo ################################################################
echo.
echo 使用前请确保以下服务已启动：
echo   [1] LS (日志服务)    — 监听 127.0.0.1:25002
echo   [2] SS (存储服务)    — 监听 127.0.0.1:25001
echo   [3] TS (事务服务)    — 监听 127.0.0.1:25003
echo.
echo 测试通过 ce CLI 与 TS 事务服务交互，验证 ACID 属性。
echo.

:menu
echo ==============================================================
echo                      A C I D  测 试 菜 单
echo ==============================================================
echo   [1] 原子性测试 (Atomicity)   — 全部完成或全部不完成
echo   [2] 一致性测试 (Consistency) — 数据库完整性不被破坏
echo   [3] 隔离性测试 (Isolation)   — 并发事务互不干扰
echo   [4] 持久性测试 (Durability)  — 提交后数据永久保存
echo   [5] 运行全部 4 项测试
echo   [6] 退出
echo ==============================================================
echo.

set "choice="
set /p choice="请输入选项 (1-6): "

if "%choice%"=="1" call :run_test "ceshi1(yuanzi).bat"
if "%choice%"=="2" call :run_test "ceshi2(yizhixing).bat"
if "%choice%"=="3" call :run_test "ceshi3(geli).bat"
if "%choice%"=="4" call :run_test "ceshi4(chijiuxing).bat"
if "%choice%"=="5" goto :run_all
if "%choice%"=="6" goto :exit
echo 无效选项，请重新输入。
pause
goto :menu

:run_all
echo.
echo ================================================================
echo              开始运行全部 4 项 ACID 测试
echo ================================================================
echo.
echo +---------------------------------------------------------------+
echo ^|  第 1 / 4 项：原子性测试 (Atomicity)                          ^|
echo +---------------------------------------------------------------+
call ceshi1^(yuanzi^).bat
echo.
echo +---------------------------------------------------------------+
echo ^|  第 2 / 4 项：一致性测试 (Consistency)                        ^|
echo +---------------------------------------------------------------+
call ceshi2^(yizhixing^).bat
echo.
echo +---------------------------------------------------------------+
echo ^|  第 3 / 4 项：隔离性测试 (Isolation)                          ^|
echo +---------------------------------------------------------------+
call ceshi3^(geli^).bat
echo.
echo +---------------------------------------------------------------+
echo ^|  第 4 / 4 项：持久性测试 (Durability)                         ^|
echo +---------------------------------------------------------------+
call ceshi4^(chijiuxing^).bat
echo.
echo ================================================================
echo           全部 ACID 测试已运行完毕！
echo   请检查上述每个 [预期] 与实际输出是否一致，
echo   以判断数据库系统是否满足 ACID 属性。
echo ================================================================
echo.
pause
goto :menu

:run_test
echo.
echo 执行: %~1
echo ----------------------------------------------------------------
call %~1
goto :eof

:exit
echo.
echo ACID 测试套件已退出。
endlocal
exit /b 0